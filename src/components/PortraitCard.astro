---
import { externalLinks, siteContent } from '../data/site';

const { profile } = siteContent;
---

<aside class="portrait-card" aria-label="Profile card for Prasith Govin">
  <div class="portrait-frame">
    <img
      src="/prasith-govin.jpg"
      alt={profile.imageAlt.value}
      data-copy-slot={profile.imageAlt.id}
      width="460"
      height="460"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <span class="portrait-scanline" aria-hidden="true"></span>
    <span class="portrait-year" aria-hidden="true">2007 → NOW</span>
  </div>
  <div class="portrait-meta">
    <div>
      <strong data-copy-slot={profile.name.id}>{profile.name.value}</strong>
      <span data-copy-slot={profile.role.id}>{profile.role.value}</span>
    </div>
    <span class="availability" data-copy-slot={profile.location.id}>
      <i aria-hidden="true"></i>{profile.location.value}
    </span>
  </div>
  <div class="portrait-links" aria-label="Social profiles">
    <a href={externalLinks.github} target="_blank" rel="noopener noreferrer">GitHub <span aria-hidden="true">↗</span></a>
    <a href={externalLinks.linkedIn} target="_blank" rel="noopener noreferrer">LinkedIn <span aria-hidden="true">↗</span></a>
    <a href={externalLinks.x} target="_blank" rel="noopener noreferrer">X <span aria-hidden="true">↗</span></a>
  </div>
</aside>
