---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import PortraitCard from '../components/PortraitCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BuildLog from '../components/BuildLog.astro';
import { externalLinks, siteContent } from '../data/site';

const { meta, hero, builds, projects, operating, experiments, contact, footer } = siteContent;
---

<BaseLayout
  title={meta.title.value}
  description={meta.description.value}
  ogTitle={meta.ogTitle.value}
  ogDescription={meta.ogDescription.value}
  imageAlt={meta.imageAlt.value}
>
  <div class="site-shell" id="top">
    <SiteNav />

    <main id="main">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="eyebrow" data-copy-slot={hero.eyebrow.id}>
            <span aria-hidden="true">01</span>{hero.eyebrow.value}
          </p>
          <h1 id="hero-title">
            <span data-copy-slot={hero.titlePrimary.id}>{hero.titlePrimary.value} </span>
            <span data-copy-slot={hero.titleSecondary.id}>{hero.titleSecondary.value}</span>
          </h1>
          <p class="hero-intro" data-copy-slot={hero.intro.id}>{hero.intro.value}</p>
          <div class="hero-actions" aria-label="Primary actions">
            <a class="button button--primary" href="#building" data-copy-slot={hero.primaryCta.id}>
              {hero.primaryCta.value}<span aria-hidden="true">↓</span>
            </a>
            <a
              class="button button--ghost"
              href="#contact"
              data-copy-slot={hero.secondaryCta.id}
            >
              {hero.secondaryCta.value}<span aria-hidden="true">↘</span>
            </a>
          </div>
          <div class="hero-signal" aria-label="Current focus areas">
            <span>PUBLIC WORK / ACTIVE BUILDS</span>
            <span><i aria-hidden="true"></i> HUMAN REVIEW / EXPLICIT BOUNDARIES</span>
          </div>
        </div>

        <div class="hero-evidence">
          <PortraitCard />
          <div class="mission-map" aria-label="Mission spine: speech, agency, and work centered on human control">
            <div class="mission-map__header">
              <span data-copy-slot={hero.proofLabel.id}>{hero.proofLabel.value}</span>
              <span>03 INPUTS / 01 OWNER</span>
            </div>
            <div class="mission-map__body">
              <span class="mission-map__center" data-copy-slot={hero.proofCenter.id}>
                <i aria-hidden="true"></i>{hero.proofCenter.value}
              </span>
              <ul>
                {hero.proofNodes.map((node, index) => (
                  <li data-copy-slot={node.id}><span>0{index + 1}</span>{node.value}</li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section class="builds-section section" id="building" aria-labelledby="builds-title">
        <div class="section-heading">
          <div>
            <p class="eyebrow" data-copy-slot={builds.kicker.id}><span aria-hidden="true">02</span>{builds.kicker.value}</p>
            <h2 id="builds-title" data-copy-slot={builds.title.id}>{builds.title.value}</h2>
          </div>
          <p data-copy-slot={builds.intro.id}>{builds.intro.value}</p>
        </div>
        <div class="project-grid">
          {projects.map((project) => <ProjectCard {...project} />)}
        </div>
      </section>

      <section class="operating-section section" id="work" aria-labelledby="operating-title">
        <div class="operating-story">
          <p class="eyebrow" data-copy-slot={operating.kicker.id}><span aria-hidden="true">03</span>{operating.kicker.value}</p>
          <h2 id="operating-title" data-copy-slot={operating.title.id}>{operating.title.value}</h2>
          <div class="operating-intro">
            {operating.body.map((paragraph) => (
              <p data-copy-slot={paragraph.id}>{paragraph.value}</p>
            ))}
          </div>

          <ol class="operating-stages" aria-label="Operating model progression">
            {operating.stages.map((stage) => (
              <li>
                <span>{stage.index}</span>
                <div>
                  <strong data-copy-slot={stage.label.id}>{stage.label.value}</strong>
                  <p data-copy-slot={stage.detail.id}>{stage.detail.value}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <aside class="principles-panel" aria-label="Working principles">
          <div class="principles-panel__header">
            <span>CONTROL PLANE</span><span>v0.1</span>
          </div>
          <ol>
            {operating.principles.map((principle, index) => (
              <li>
                <span>0{index + 1}</span>
                <p data-copy-slot={principle.id}>{principle.value}</p>
              </li>
            ))}
          </ol>
          <div class="principles-panel__footer"><i aria-hidden="true"></i> HUMAN OWNER REQUIRED</div>
        </aside>
      </section>

      <section class="experiments-section section" id="experiments" aria-labelledby="experiments-title">
        <div class="section-heading section-heading--experiments">
          <div>
            <p class="eyebrow" data-copy-slot={experiments.kicker.id}><span aria-hidden="true">04</span>{experiments.kicker.value}</p>
            <h2 id="experiments-title" data-copy-slot={experiments.title.id}>{experiments.title.value}</h2>
          </div>
          <p data-copy-slot={experiments.intro.id}>{experiments.intro.value}</p>
        </div>
        <BuildLog />
      </section>

      <section class="contact-section section" id="contact" aria-labelledby="contact-title">
        <div class="contact-orbit" aria-hidden="true"><i></i><i></i><i></i><span>PG</span></div>
        <div class="contact-copy">
          <p class="eyebrow" data-copy-slot={contact.kicker.id}><span aria-hidden="true">05</span>{contact.kicker.value}</p>
          <h2 id="contact-title" data-copy-slot={contact.title.id}>{contact.title.value}</h2>
          <p data-copy-slot={contact.body.id}>{contact.body.value}</p>
          <div class="contact-actions">
            <a
              class="button button--primary"
              href={externalLinks.linkedIn}
              target="_blank"
              rel="noopener noreferrer"
              data-copy-slot={contact.linkedIn.id}
            >
              {contact.linkedIn.value}<span aria-hidden="true">↗</span>
            </a>
            <a
              class="button button--ghost"
              href={externalLinks.github}
              target="_blank"
              rel="noopener noreferrer"
              data-copy-slot={contact.github.id}
            >
              {contact.github.value}<span aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <span data-copy-slot={footer.legal.id}>{footer.legal.value}</span>
      <span data-copy-slot={footer.note.id}>{footer.note.value}</span>
      <nav aria-label="Footer links">
        <a href={externalLinks.github} target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href={externalLinks.linkedIn} target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href={externalLinks.x} target="_blank" rel="noopener noreferrer">X</a>
        <a href="#top">Top ↑</a>
      </nav>
    </footer>
  </div>
</BaseLayout>
